# Adrian configuration. Generated by `adrian-setup bootstrap` and
# read by docker compose. Do not commit your filled-in copy; .env is
# ignored by .gitignore.

# Classifier LLM endpoint. POSTed to verbatim by the engine (no path
# appending). Points at the bundled llama.cpp container (compose
# service `llm`, profile `llm`).
ADRIAN_LLM_URL=http://adrian-llm:8081/v1/chat/completions

# In-container path to the GGUF file under ./models/ (host) /
# /models/ (container). Set by `bootstrap --gguf <name>`. Read by the
# `llm` compose service.
ADRIAN_LLM_MODEL_PATH=/models/gemma-4-E4B-it-Q4_K_M.gguf

# Bearer token sent as `Authorization: Bearer ...`. The bundled
# llama.cpp server doesn't enforce auth, so the placeholder is fine.
ADRIAN_LLM_API_KEY=local-no-auth

# Model id sent in the request body's `model` field. The bundled
# llama.cpp server reads this loosely (the loaded model is the only
# one it can serve).
ADRIAN_LLM_MODEL=local

# Llama.cpp context window. Higher = more history, more VRAM.
ADRIAN_LLM_CTX_SIZE=8192

# Sliding-window context. Each (session_id, invocation_id, agent_id)
# tuple keeps a ring buffer of the last N classified turns; the
# classifier prepends them as user/assistant pairs so M3-class
# detections that need cross-step context can fire. Restart loses
# the in-memory window; the per-key lock that serialises
# read-classify-publish-push is process-local.
ADRIAN_SLIDING_WINDOW_SIZE=16
ADRIAN_SLIDING_WINDOW_TTL_SECONDS=86400

# Listen ports (host-side).
ADRIAN_BACKEND_PORT=8080
ADRIAN_DASHBOARD_PORT=3000

# Session cookie secret. Generated by setup; do not commit.
ADRIAN_SESSION_SECRET=
