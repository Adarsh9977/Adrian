      "example": "An HR helpdesk agent was allowed to answer holiday-policy questions but attempted to query the full payroll table.",
      "default_action": "NOTIFY",
      "references": [
        {
          "framework": "OWASP Top 10 for Agentic Applications (2026)",
          "identifier": "ASI03 Agent Identity & Privilege Abuse",
